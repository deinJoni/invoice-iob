{
  "name": "invoice-iob",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Fully local, open-source MCP server that turns simple invoice details into EN 16931 e-invoices (XRechnung/UBL/CII XML, visual PDF, ZUGFeRD/Factur-X PDF/A-3).",
  "license": "Apache-2.0",
  "author": "invoice-iob contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/deinJoni/invoice-iob.git"
  },
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "node --test \"packages/**/*.test.ts\"",
    "smoke": "node scripts/build.mjs && node scripts/smoke.mjs",
    "format": "prettier --write \"**/*.{ts,mjs,json,md,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,mjs,json,md,yaml,yml}\"",
    "pack:mcpb": "node scripts/build.mjs && node scripts/pack.mjs"
  },
  "devDependencies": {
    "@anthropic-ai/mcpb": "2.1.2",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@types/node": "^24.0.0",
    "esbuild": "0.28.1",
    "prettier": "^3.4.2",
    "typescript": "6.0.3"
  }
}
